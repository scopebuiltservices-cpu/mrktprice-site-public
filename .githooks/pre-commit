#!/bin/sh
# MrktPrice pre-commit hook — runs the ONE-COMMAND, CI-equivalent gate (tools/verify_all.sh)
# so nothing un-gated reaches GitHub. verify_all.sh runs: py_compile all *.py, every
# test_*.py + test_*.mjs, inline + external <script> checks, JSON validity, and the
# payload schema gates (marketmap/xsection/cik/alpha_calib/events/universe).
#
# Enable once per clone:          git config core.hooksPath .githooks
# Bypass once (not recommended):  git commit --no-verify
#
# Fast mode: set MRKT_PRECOMMIT_FAST=1 to only check STAGED files (skips the full suite)
# for quick WIP commits; the full gate still runs in CI regardless.

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 2

if [ "${MRKT_PRECOMMIT_FAST:-0}" = "1" ]; then
  echo "pre-commit (FAST): staged-file checks only ..."
  fail=0
  node tools/check-scripts.mjs || { echo "x inline <script> syntax error"; fail=1; }
  for f in $(git diff --cached --name-only --diff-filter=ACM | grep '\.py$'); do
    python3 -m py_compile "$f" 2>/dev/null || { echo "x Python syntax error in $f"; fail=1; }
  done
  for j in $(git diff --cached --name-only --diff-filter=ACM | grep '\.json$'); do
    python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$j" 2>/dev/null || { echo "x invalid/truncated JSON: $j"; fail=1; }
  done
  [ "$fail" -ne 0 ] && { echo "  Fix the above, or bypass with: git commit --no-verify"; exit 1; }
  exit 0
fi

echo "pre-commit: running tools/verify_all.sh (full gate) ..."
if [ -x tools/verify_all.sh ]; then
  tools/verify_all.sh
else
  sh tools/verify_all.sh
fi
rc=$?
if [ "$rc" -ne 0 ]; then
  echo ""
  echo "pre-commit: VERIFY_ALL FAILED — commit blocked. Fix the failures above,"
  echo "            run a WIP commit with MRKT_PRECOMMIT_FAST=1, or bypass with --no-verify."
  exit 1
fi
echo "pre-commit: all gates passed."
exit 0
