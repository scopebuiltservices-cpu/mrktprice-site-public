{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mrktprice.com/schemas/alpha_calib.schema.json",
  "title": "alpha_calib",
  "description": "Cross-sectional alpha->forward-return calibration emitted by alpha_calib.py.",
  "type": "object",
  "required": ["asof", "horizonDays", "n", "mode"],
  "properties": {
    "asof": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}" },
    "horizonDays": { "type": "integer", "minimum": 1 },
    "n": { "type": "integer", "minimum": 0 },
    "sigFallback": { "type": ["number", "null"] },
    "coef": { "type": ["number", "null"] },
    "intercept": { "type": ["number", "null"] },
    "ic": { "type": ["number", "null"], "minimum": -1.0001, "maximum": 1.0001 },
    "rankIC": { "type": ["number", "null"], "minimum": -1.0001, "maximum": 1.0001 },
    "mode": { "enum": ["fallback", "fitted"] }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "fitted" } } },
      "then": { "properties": { "coef": { "type": "number" }, "ic": { "type": "number" } }, "required": ["coef", "ic"] }
    }
  ]
}
