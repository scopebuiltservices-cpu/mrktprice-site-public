{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mrktprice.com/schemas/fib_forecast.schema.json",
  "title": "fib_forecast",
  "description": "Immutable multi-horizon (Fibonacci/cadence) projection record emitted by the fib engine.",
  "type": "object",
  "required": ["schemaVersion", "asof", "assetClass", "horizonPreset", "priceNow", "params", "horizons"],
  "$defs": {
    "horizon": {
      "type": "object",
      "required": ["H", "targetDate", "projLog", "projPrice", "sigmaH", "capped", "lo", "hi", "bandMethod"],
      "properties": {
        "H": { "type": "integer", "minimum": 1 },
        "targetDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}" },
        "projLog": { "type": "number" },
        "projPrice": { "type": "number", "exclusiveMinimum": 0 },
        "muLog": { "type": "number" },
        "sigmaH": { "type": "number", "minimum": 0 },
        "zEdge": { "type": ["number", "null"] },
        "capped": { "type": "boolean" },
        "source": { "enum": ["direct", "fallback"] },
        "lo": { "type": "number", "exclusiveMinimum": 0 },
        "hi": { "type": "number", "exclusiveMinimum": 0 },
        "bandMethod": { "enum": ["conformal", "parametric"] }
      }
    }
  },
  "properties": {
    "schemaVersion": { "type": "string" },
    "asof": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}" },
    "assetClass": { "enum": ["equity", "crypto"] },
    "horizonPreset": { "enum": ["cadence", "fib", "powers"] },
    "priceNow": { "type": "number", "exclusiveMinimum": 0 },
    "modelVersion": { "type": "string" },
    "featureVersion": { "type": "string" },
    "dataVersion": { "type": "string" },
    "params": {
      "type": "object",
      "required": ["halflife", "sigmaDaily"],
      "properties": {
        "halflife": { "type": "number", "exclusiveMinimum": 0 },
        "sigmaDaily": { "type": "number", "minimum": 0 },
        "volBlend": { "type": ["object", "null"] }
      }
    },
    "horizons": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/horizon" } }
  }
}
